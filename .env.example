# Testnet2 gateway key — PUBLIC, not a secret (see PHASE0_VERIFIED_API.md #1 / README of the
# installed SDK). Safe to commit and to keep in this .env.example.
ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590

# Network name used end-to-end for the wallet-api rails (must be exactly 'testnet2' — it is a
# server-side blob-key prefix, not just a label; see PHASE0_VERIFIED_API.md #3.2).
NETWORK=testnet2

# wallet-api deployment (delivery mailbox + own-storage rails).
WALLET_API_BASE_URL=https://wallet-api.unicity.network

# Nametag prefixes — a random 6-hex-char suffix is generated once and persisted per wallet
# role (see src/wallet/init.ts). Unicity IDs are capped at 20 chars total, so keep prefixes
# <= 13 chars (init.ts validates this and throws a clear error if you don't).
AGENT_NAMETAG_PREFIX=cpa-agent
COUNTERPARTY_NAMETAG_PREFIX=cpa-peer

# Set by scripts/run-agent-wallet.ts on first run / read by scripts/counterparty-send.ts —
# TODO: fill in once you know the agent's registered nametag, or leave unset and pass
# --to on the command line.
# AGENT_NAMETAG=

# TODO (user-provided): external nametag for scripts/send-external.ts (Phase 1 step 5).
# EXTERNAL_TEST_NAMETAG=

# Phase 4 dashboard (served from INSIDE scripts/run-agent.ts — see src/server/dashboard-server.ts).
# Defaults to loopback-only, which is safe but not reachable by a remote reviewer. Making the
# dashboard "live, publicly viewable" (CLAUDE.md mục 8/9) is a deployment decision left to you —
# e.g. set DASHBOARD_HOST=0.0.0.0 behind a firewalled VPS/reverse-proxy, or front the loopback
# port with a tunnel (ngrok/Cloudflare Tunnel/etc). See PHASE4_REPORT.md TODOs.
# DASHBOARD_PORT=8787
# DASHBOARD_HOST=127.0.0.1
